generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Vault {
  id                 String   @id @default(cuid())
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ciphertext         String
  iv                 String
  authTag            String
  wrappedDekPass     String
  wrappedDekRecovery String
  saltPass           String
  saltRecovery       String
  kdfParams          Json
  schemaVersion      Int      @default(1)
  recoveryVerifiedAt DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

enum DeadmanReleaseStatus {
  armed
  grace_period
  released
  cancelled
}

enum ReleaseAuditEventType {
  backup_uploaded
  backup_deleted
  grace_started
  owner_warning_sent
  grace_cancelled
  release_executed
  release_email_sent
  release_email_ignored
  release_failed
  retrieval_token_created
  test_email_sent
  retrieval_viewed
  retrieval_downloaded
  retrieval_accepted
  retrieval_expired
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  vault         Vault?
  accounts      Account[]
  sessions      Session[]
  readinessSnapshots UserReadinessSnapshot[]
  checklistProgress  UserChecklistProgress?
  privacyConsent     UserPrivacyConsent?
  vaultBackup        VaultBackup?
  deadmanReleaseState DeadmanReleaseState?
  trustedContactReleaseChannels TrustedContactReleaseChannel[]
  releaseAuditEvents ReleaseAuditEvent[]
  releaseRetrievalTokens ReleaseRetrievalToken[]
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([providerId, accountId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
}

model UserReadinessSnapshot {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  readinessPercent Int
  completedCount  Int
  totalCount      Int
  createdAt       DateTime @default(now())

  @@index([userId, createdAt])
}

model UserChecklistProgress {
  id                 String   @id @default(cuid())
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  assetsMapped       Boolean  @default(false)
  debtsRecorded      Boolean  @default(false)
  digitalLegacyAdded Boolean  @default(false)
  wishesCompleted    Boolean  @default(false)
  trustedContactAdded Boolean @default(false)
  recoveryKeySaved   Boolean  @default(false)
  recoveryTested     Boolean  @default(false)
  updatedAt          DateTime @updatedAt
}

model UserPrivacyConsent {
  id           String    @id @default(cuid())
  userId       String    @unique
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  backupEnabled Boolean  @default(false)
  consentedAt  DateTime?
  revokedAt    DateTime?
  updatedAt    DateTime  @updatedAt
}

// SQLite-based encrypted vault backup (replaces Google Drive)
model VaultBackup {
  id                  String   @id @default(cuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Encrypted vault payload stored directly in SQLite
  ciphertext          String   // Base64-encoded encrypted vault data
  iv                  String   // Initialization vector
  authTag             String   // Authentication tag
  // Key wrapping (same as local vault)
  wrappedDekPass      String   // Data encryption key wrapped with passphrase
  wrappedDekRecovery  String   // Data encryption key wrapped with recovery key
  saltPass            String   // Salt for passphrase KDF
  saltRecovery        String   // Salt for recovery key KDF
  kdfParams           Json     // Argon2id params
  schemaVersion       Int      @default(1)
  // Metadata
  lastBackedUpAt      DateTime @default(now())
  backupFingerprint   String   // Hash of ciphertext for integrity checks
  recoveryVerifiedAt  DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model DeadmanReleaseState {
  id                String               @id @default(cuid())
  userId            String               @unique
  user              User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  status            DeadmanReleaseStatus @default(armed)
  lastCheckInAt     DateTime?
  missedAt          DateTime?
  graceEndsAt       DateTime?
  releasedAt        DateTime?
  cancelledAt       DateTime?
  ownerWarningSentAt DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
}

model TrustedContactReleaseChannel {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  trustedContactId String
  releaseEmail    String
  phoneNumber     String?
  emailIgnored    Boolean  @default(false)
  firstViewedAt   DateTime?
  downloadedAt    DateTime?
  acceptedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([userId, trustedContactId])
  @@index([userId])
}

model ReleaseRetrievalToken {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  trustedContactId String
  tokenHash       String   @unique
  expiresAt       DateTime
  usedAt          DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId, trustedContactId])
}

model ReleaseAuditEvent {
  id              String               @id @default(cuid())
  userId          String
  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  trustedContactId String?
  type            ReleaseAuditEventType
  occurredAt      DateTime             @default(now())
  metadataJson    Json?

  @@index([userId, occurredAt])
  @@index([userId, trustedContactId, occurredAt])
}

// Email retry queue for failed release notifications
model EmailRetryQueue {
  id                String   @id @default(cuid())
  userId            String
  trustedContactId  String?
  emailType         String   // "owner_warning" | "contact_release"
  recipientEmail    String
  subject           String
  bodyText          String
  bodyHtml          String
  attemptCount      Int      @default(0)
  lastAttemptAt     DateTime?
  nextAttemptAt     DateTime
  status            String   @default("pending") // pending | processing | failed | sent
  errorMessage      String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([status, nextAttemptAt])
  @@index([userId])
}
